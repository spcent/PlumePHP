{
  "name": "spcent/plumephp",
  "type": "library",
  "description": "一个单文件极简的php框架，可运行在fpm或者swoole协程模式下",
  "keywords": [
    "swoole",
    "framework",
    "async",
    "plumephp"
  ],
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "spcent",
      "email": "spcent@qq.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "psr/log": "^3.0",
    "psr/container": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Plume\\": "library/Plume/"
    },
    "files": [
      "library/PlumePHP.php"
    ]
  },
  "suggest": {
    "ext-redis": "如果缓存驱动为Redis",
    "ext-swoole": "常驻内存运行必须的扩展",
    "ext-pdo": "数据库驱动"
  },
  "require-dev": {
    "phpunit/phpunit": "^9"
  },
  "scripts": {
    "build": "php scripts/build.php"
  }
}
